# Required, set your Anthropic API key.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Optional, uncomment and set when running without the Slack CLI (npm start).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Optional, uncomment and set for OAuth mode (node app-oauth.js).
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL

# --- Field operations extensions ---

# Procore MCP connection (create_procore_issue, check_for_contradictions).
# See agent/mcp/procore.js for the options (official Procore MCP, Pipedream
# hosted MCP, or a self-hosted community server).
# PROCORE_MCP_URL=YOUR_PROCORE_MCP_URL
# PROCORE_MCP_TOKEN=YOUR_PROCORE_MCP_TOKEN

# Twilio (trigger_safety_broadcast, inbound SMS webhook).
# TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
# TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
# TWILIO_FROM_NUMBER=YOUR_TWILIO_FROM_NUMBER

# Database (lib/db.js) — worker directory, sites, broadcasts, acknowledgments.
# DATABASE_URL=YOUR_POSTGRES_OR_SUPABASE_CONNECTION_STRING

# Translation (lib/translate.js).
# TRANSLATE_API_KEY=YOUR_DEEPL_OR_GOOGLE_TRANSLATE_API_KEY
