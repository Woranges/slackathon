{
  "name": "slackathon",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check": "npx tsc --checkJs --noEmit --skipLibCheck --esModuleInterop --target esnext --module nodenext --moduleResolution nodenext app.js",
    "start": "node app.js",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "test": "node --test"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@slack/bolt": "^4.7.3",
    "dotenv": "~17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@slack/cli-hooks": "^1.3.3",
    "typescript": "^6.0.3"
  }
}
